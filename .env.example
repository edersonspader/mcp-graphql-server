# GraphQL endpoint URL (required for live introspection)
GRAPHQL_URL=https://your-api.example.com/graphql

# Bearer token for the GraphQL endpoint (optional)
GRAPHQL_TOKEN=your-bearer-token

# Enable file cache: true (default) | false
# - true : schema cached under var/cache/ — avoids re-fetching on every startup
# - false : disables caching; fetches fresh from URL on every server startup
CACHE_ENABLED=true

# Schema cache TTL in seconds (default: 3600 = 1 hour)
CACHE_TTL=3600

# Fallback static introspection file — used when GRAPHQL_URL is not set
# INTROSPECTION_FILE=/app/mcp/graphql/schema/schema.json
