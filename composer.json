{
    "description": "MCP server for GraphQL schema introspection",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.5",
        "guzzlehttp/guzzle": "^7.0",
        "mcp/sdk": "^0.4",
        "monolog/monolog": "^3.0",
        "psr/simple-cache": "^3.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^13.0",
        "symfony/cache": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        },
        "sort-packages": true
    },
    "scripts": {
        "analyse": "phpstan analyse --no-progress",
        "serve": "php server.php",
        "test": "phpunit"
    }
}